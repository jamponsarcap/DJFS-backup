# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Azure AI Search ────────────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<your-key>
AZURE_SEARCH_INDEX=portfolio-docs

# ── Azure Document Intelligence ────────────────────────────────────────────────
AZURE_DOC_INTEL_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTEL_KEY=<your-key>

# ── Microsoft Fabric / OneLake SQL ────────────────────────────────────────────
# Leave blank to use mock data
FABRIC_SERVER=<your-workspace>.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=<your-lakehouse>
# Uses DefaultAzureCredential (Entra ID) – no password needed

# ── External Market Data ──────────────────────────────────────────────────────
# Optional: leave blank to use cached mock prices
MARKET_DATA_API_KEY=<your-alpha-vantage-or-similar-key>

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
